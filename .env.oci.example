# OCI Kafka MCP Server — OCI Streaming with Apache Kafka Configuration
# Copy this file to .env.oci and fill in your cluster details:
#   cp .env.oci.example .env.oci
#
# Then source it before running the MCP server:
#   source .env.oci
#   .venv/bin/oci-kafka-mcp --allow-writes

# Bootstrap servers — from OCI Console > Cluster > Cluster Information
export KAFKA_BOOTSTRAP_SERVERS="<your-bootstrap-url>:9092"

# Security protocol — SASL_SSL for SCRAM auth, SSL for mTLS
export KAFKA_SECURITY_PROTOCOL="SASL_SSL"

# SASL mechanism — OCI Kafka uses SCRAM-SHA-512
export KAFKA_SASL_MECHANISM="SCRAM-SHA-512"

# SASL credentials — from the OCI Vault secret you configured
export KAFKA_SASL_USERNAME="<your-sasl-username>"
export KAFKA_SASL_PASSWORD="<your-sasl-password>"

# CA certificate — OCI uses publicly trusted certs
# Option 1: System CA bundle (works on macOS)
export KAFKA_SSL_CA_LOCATION="/etc/ssl/cert.pem"
# Option 2: Python certifi bundle (alternative)
# export KAFKA_SSL_CA_LOCATION="/opt/homebrew/lib/python3.13/site-packages/certifi/cacert.pem"
